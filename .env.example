# ==============================================================================
# VARIABLES DE ENTORNO — FinanceTracker (Plantilla / Ejemplo para Git)
# ==============================================================================
# Copia este archivo como .env en la raíz o configura estas variables en el 
# entorno del sistema operativo / nube (Render, Vercel, Windows).
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. SCRIPTS DE OPERACIÓN TI (Respaldo y Restauración automática con Aiven)
# Usadas por: scripts/operacion_ti/backup_finanzas_db.ps1 y restore_finanzas_db.ps1
# ------------------------------------------------------------------------------
AIVEN_PASSWORD=TU_CONTRASEÑA_DE_AIVEN_AQUI
DB_PASSWORD=TU_CONTRASEÑA_DE_AIVEN_AQUI

# ------------------------------------------------------------------------------
# 2. BACKEND (Spring Boot - application.properties / Render Cloud)
# En Render estas variables sobrescriben automáticamente a application.properties
# ------------------------------------------------------------------------------
# Puerto de ejecución del servidor web (Render inyecta PORT=10000 por defecto)
PORT=8081

# Conexión a Base de Datos MySQL (Si se configuran en nube o Docker)
SPRING_DATASOURCE_URL=jdbc:mysql://mysql-14aa6667-janitojahuarc-ec57.c.aivencloud.com:26994/defaultdb?useSSL=true&requireSSL=true
SPRING_DATASOURCE_USERNAME=avnadmin
SPRING_DATASOURCE_PASSWORD=TU_CONTRASEÑA_DE_AIVEN_AQUI

# ------------------------------------------------------------------------------
# 3. FRONTEND (React / Vercel / Vite)
# Archivo: finanzas-app-frontend/.env
# ------------------------------------------------------------------------------
# URL base de la API Backend (en desarrollo local apunta a localhost, en Vercel a Render)
REACT_APP_API_URL=http://localhost:8081/api
VITE_API_URL=https://finanzas-app-backend.onrender.com/api
DANGEROUSLY_DISABLE_HOST_CHECK=true
